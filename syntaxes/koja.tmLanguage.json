{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Koja",
  "scopeName": "source.koja",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#annotations" },
    { "include": "#function-definition" },
    { "include": "#function-call" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#primitive-types" },
    { "include": "#package-constants" },
    { "include": "#package-qualifier" },
    { "include": "#types" },
    { "include": "#typed-assignment" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.koja",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.koja",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            { "include": "#string-interpolation" },
            { "include": "#string-escape" }
          ]
        },
        {
          "name": "string.quoted.double.koja",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "include": "#string-interpolation" },
            { "include": "#string-escape" }
          ]
        }
      ]
    },
    "string-interpolation": {
      "patterns": [
        {
          "name": "meta.interpolation.koja",
          "begin": "#\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.section.interpolation.begin.koja" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.section.interpolation.end.koja" }
          },
          "patterns": [{ "include": "source.koja" }]
        }
      ]
    },
    "string-escape": {
      "patterns": [
        {
          "name": "constant.character.escape.koja",
          "match": "\\\\[nrt\\\\\"#0]"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.koja",
          "match": "\\b0x[0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "name": "constant.numeric.binary.koja",
          "match": "\\b0b[01][01_]*\\b"
        },
        {
          "name": "constant.numeric.float.koja",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*\\b"
        },
        {
          "name": "constant.numeric.integer.koja",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "storage.type.annotation.koja",
          "match": "@\\w+"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow.koja",
          "match": "\\b(if|else|unless|match|cond|when|return|break)\\b"
        },
        {
          "name": "keyword.control.loop.koja",
          "match": "\\b(for|loop|while|in)\\b"
        },
        {
          "name": "keyword.control.concurrency.koja",
          "match": "\\b(spawn|receive|after)\\b"
        },
        {
          "name": "keyword.other.fn.koja",
          "match": "\\b(fn|priv)\\b"
        },
        {
          "name": "keyword.other.end.koja",
          "match": "\\bend\\b"
        },
        {
          "name": "keyword.other.koja",
          "match": "\\b(const|extend|impl|type|alias|as)\\b"
        },
        {
          "name": "storage.type.koja",
          "match": "\\b(struct|enum|protocol)\\b"
        },
        {
          "name": "keyword.operator.logical.koja",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "constant.language.boolean.koja",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.none.koja",
          "match": "\\bnone\\b"
        },
        {
          "name": "variable.language.self.koja",
          "match": "\\bself\\b"
        },
        {
          "name": "variable.language.self-type.koja",
          "match": "\\bSelf\\b"
        },
        {
          "name": "constant.numeric.modifier.koja",
          "match": "\\b(signed|unsigned|big|little|byte)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.koja",
          "match": "->"
        },
        {
          "name": "keyword.operator.binary-literal.koja",
          "match": "<<|>>|<>"
        },
        {
          "name": "keyword.operator.size-separator.koja",
          "match": "::"
        },
        {
          "name": "keyword.operator.comparison.koja",
          "match": "[!=]=|[<>]=?"
        },
        {
          "name": "keyword.operator.assignment.compound.koja",
          "match": "[+\\-*/%]="
        },
        {
          "name": "keyword.operator.assignment.koja",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.koja",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.union.koja",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.optional.koja",
          "match": "\\?"
        }
      ]
    },
    "primitive-types": {
      "patterns": [
        {
          "name": "support.type.primitive.koja",
          "match": "\\b(Binary|Bits|Bool|Float32|Float64|Float|Int8|Int16|Int32|Int64|Int|String|UInt8|UInt16|UInt32|UInt64)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.koja",
          "match": "\\b[A-Z][a-zA-Z0-9]*\\b"
        }
      ]
    },
    "package-constants": {
      "patterns": [
        {
          "name": "constant.other.koja",
          "match": "\\b[A-Z][A-Z0-9_]{1,}\\b"
        }
      ]
    },
    "package-qualifier": {
      "patterns": [
        {
          "comment": "Packages are PascalCase and only ever appear as the head of a dotted path: `Net.TCPSocket`, `HTTP.Headers.new()`, `alias JSON.Encoder as JSONEncoder`. Match the leading PascalCase token when followed by `.PascalCase` so it gets the namespace classification rather than the generic type rule.",
          "match": "\\b([A-Z][a-zA-Z0-9]*)(?=\\.[A-Z])",
          "captures": {
            "1": { "name": "entity.name.namespace.koja" }
          }
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+([a-z_][a-z0-9_]*\\??)",
          "captures": {
            "1": { "name": "keyword.other.fn.koja" },
            "2": { "name": "entity.name.function.koja" }
          }
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "meta.function-call.koja",
          "match": "\\b([a-z_][a-z0-9_]*\\??)\\s*(?:<[^>]*>)?\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.koja" }
          }
        }
      ]
    },
    "typed-assignment": {
      "patterns": [
        {
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(:)\\s*",
          "captures": {
            "1": { "name": "variable.other.koja" },
            "2": { "name": "punctuation.separator.type.koja" }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.koja",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
