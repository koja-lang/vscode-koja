{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(fn|if|else|for|loop|while|match|cond|receive|struct|enum|protocol|impl|extend|unless|when|do)\\b",
    "decreaseIndentPattern": "^\\s*(end|else)\\b"
  },
  "folding": {
    "markers": {
      "start": "^\\s*(fn|if|for|loop|while|match|cond|receive|struct|enum|protocol|impl|extend)\\b",
      "end": "^\\s*end\\b"
    }
  }
}
